# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Anthropic (direct API or proxy)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Or use a proxy:
# ANTHROPIC_BASE_URL=http://your-proxy:4321
# ANTHROPIC_AUTH_TOKEN=sk-1234

# Optional: Model override (default: bedrock-claude-opus-4-7-1m)
# ANTHROPIC_MODEL=bedrock-claude-opus-4-7-1m

# OpenAI (for voice message transcription via Whisper)
# OPENAI_API_KEY=your_openai_api_key_here

# EigenAI (for voice assistant STT/TTS)
# EIGENAI_API_KEY=your_eigenai_api_key_here

# ElevenLabs (for voice coach TTS)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here

# Voice Coach LLM model (default: bedrock-claude-sonnet-4-1m)
# COACH_MODEL=bedrock-claude-sonnet-4-1m

# Gateway Dashboard
GATEWAY_PORT=3000
GATEWAY_TOKEN=your_secret_gateway_token_here
# GATEWAY_PUBLIC_URL=https://your-public-url.com  # Public URL for artifact links

# Session
# SESSION_TTL_HOURS=24

# Evolution Engine
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...  # start.sh notifications
# DAYTONA_API_KEY=your_daytona_key                          # Sandbox CI for evolution validation
# DAYTONA_API_URL=https://app.daytona.io/api                # Daytona API endpoint

# Reflection System
# REFLECTION_CHANNEL_ID=your_channel_id_here
# REFLECTION_INTERVAL_HOURS=6
# REFLECTION_LOOKBACK_HOURS=24
# REFLECTION_MIN_SIGNALS=3
# REFLECTION_MODEL=                # Defaults to ANTHROPIC_MODEL

# Voice Assistant
# VOICE_MODEL=claude-sonnet-4-20250514     # Or eigen:<model> for Eigen LLM
# VOICE_SILENCE_MS=800                      # Silence to end utterance (ms)
# VOICE_MIN_UTTERANCE_MS=500                # Skip noise shorter than this (ms)
# VOICE_MAX_TOKENS=512                      # Max tokens for voice responses
# VOICE_DEBUG=1                             # Set 0 to disable debug logging
# VOICE_TTS_STREAM=1                        # Set 0 to disable streaming TTS
# VOICE_TOOLS_MODE=full                     # full or minimal
# VOICE_REFERENCE_FILE=path/to/reference.mp3  # TTS voice cloning reference audio
