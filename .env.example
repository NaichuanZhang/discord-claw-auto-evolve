# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Anthropic (direct API or proxy)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Or use a proxy:
# ANTHROPIC_BASE_URL=http://your-proxy:4321
# ANTHROPIC_AUTH_TOKEN=sk-1234

# OpenAI (for voice message transcription via Whisper)
# OPENAI_API_KEY=your_openai_api_key_here

# Gateway Dashboard
GATEWAY_PORT=3000
GATEWAY_TOKEN=your_secret_gateway_token_here

# Optional
SESSION_TTL_HOURS=24
ANTHROPIC_MODEL=bedrock-claude-opus-4-6-1m
LOG_LEVEL=info

# Evolution Engine (start.sh notifications)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
